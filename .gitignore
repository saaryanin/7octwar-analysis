# Ignore generated SQLite databases
*.db

# Ignore data files but keep the folders and .gitkeep files
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/.gitkeep

# Ignore common Python/IDE files
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
*.env
.env

# Ignore OS files
.DS_Store
Thumbs.db